# .sqlfluff
# SQLFluff configuration for the salesforce_dbt project.
# Ref: https://docs.sqlfluff.com/en/stable/configuration.html

[sqlfluff]
templater       = dbt
dialect         = snowflake
sql_file_exts   = .sql
max_line_length = 120

# Rules to exclude project-wide
exclude_rules =
    # L016: Line too long — max_line_length handles this
    L016,
    # L036: Select wildcards — we use SELECT * in snapshots intentionally
    L036,
    # AM04: Avoid SELECT * — same as above
    AM04,
    # RF04: Reserved keywords — Snowflake has some that sqlfluff flags incorrectly
    RF04

[sqlfluff:templater:dbt]
project_dir = .
profiles_dir = ~/.dbt
profile = salesforce_dbt
target = dev

[sqlfluff:rules:layout.long_lines]
ignore_comment_lines = true
ignore_comment_clauses = true

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:aliasing.table]
aliasing = explicit

[sqlfluff:rules:aliasing.column]
aliasing = explicit

[sqlfluff:rules:convention.select_trailing_comma]
select_clause_trailing_comma = forbid
